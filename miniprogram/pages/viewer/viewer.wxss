.viewer-page { min-height: 100vh; color: #ffffff; background: #111715; }
.player-shell { position: relative; width: 100%; height: 62vh; background: #000000; }
.video-player { width: 100%; height: 100%; display: block; background: #000000; }
.image-shell { position: relative; width: 100%; height: 72vh; background: #000000; }
.image-player { width: 100%; height: 100%; display: block; }
.viewer-arrow { position: absolute; z-index: 4; top: 50%; width: 78rpx; height: 104rpx; margin: 0; padding: 0; border: 1rpx solid rgba(255,255,255,.18); border-radius: 10rpx; color: #ffffff; background: rgba(8,12,11,.55); font-size: 58rpx; line-height: 96rpx; transform: translateY(-50%); }
.viewer-arrow.previous { left: 22rpx; }
.viewer-arrow.next { right: 22rpx; }
.player-loading, .player-error { position: absolute; z-index: 2; top: 0; right: 0; bottom: 0; left: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40rpx; color: rgba(255,255,255,.72); background: #000000; font-size: 24rpx; text-align: center; }
.player-error button { width: 180rpx; height: 68rpx; margin-top: 24rpx; border-radius: 8rpx; color: #ffffff; background: #21483f; font-size: 23rpx; line-height: 68rpx; }
.video-copy { padding: 30rpx 28rpx calc(30rpx + env(safe-area-inset-bottom)); }
.video-name, .video-meta { display: block; }
.video-name { overflow: hidden; font-size: 30rpx; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.video-meta { margin-top: 12rpx; color: rgba(255,255,255,.56); font-size: 22rpx; }
