<view class="library-page safe-bottom {{editMode ? 'editing' : ''}}">
  <view class="member-bar">
    <view class="identity">
      <button class="menu-button" bindtap="toggleFolderMenu" aria-label="打开文件目录">
        <view class="menu-line" />
        <view class="menu-line" />
        <view class="menu-line" />
      </button>
      <image class="logo" src="/images/logo.png" mode="aspectFill" />
      <view class="identity-copy">
        <text class="album-name">伞兵训练营的时光集</text>
        <text class="member-title {{user.title ? 'is-shiny' : ''}}">{{user.title || user.permissionLabel}}</text>
        <text class="member-name">{{user.displayName || user.accountLabel}} · {{user.permissionLabel}}</text>
      </view>
    </view>
    <button class="logout-button" bindtap="logout">退出</button>
  </view>

  <view wx:if="{{user.canManagePermissions}}" class="admin-tabs">
    <button class="active">相册</button>
    <button bindtap="openPermissionsPage">用户权限</button>
  </view>

  <view class="folder-menu-backdrop" wx:if="{{folderMenuOpen}}" bindtap="closeFolderMenu">
    <view class="folder-menu-panel" catchtap="noop">
      <view class="folder-menu-header">
        <view>
          <text class="folder-menu-eyebrow">伞兵训练营</text>
          <text class="folder-menu-title">文件目录</text>
        </view>
        <button class="folder-menu-close" bindtap="closeFolderMenu" aria-label="关闭文件目录">×</button>
      </view>
      <button wx:if="{{user.canManageFolders}}" class="create-folder-menu-button" bindtap="openCreateFolder" disabled="{{creatingFolder}}">＋ 新建文件夹</button>
      <button wx:if="{{user.canOpenPeople}}" class="manage-users-menu-button" bindtap="openUserManagement">{{user.canManagePermissions ? '用户权限' : '称号管理'}}</button>
      <scroll-view class="folder-menu-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="folder-menu-row">
          <button class="folder-menu-main {{selectedFolder === '' && !recycleMode ? 'active' : ''}}" data-slug="" bindtap="chooseFolder">
            <text>全部影像</text><text class="folder-count">全部</text>
          </button>
        </view>
        <view class="folder-menu-row" wx:for="{{folders}}" wx:key="id">
          <button class="folder-menu-main {{selectedFolder === item.slug && !recycleMode ? 'active' : ''}}" data-slug="{{item.slug}}" bindtap="chooseFolder">
            <text class="folder-menu-name">{{item.name}}</text>
            <text class="visibility-mark {{item.visibilityType}}">{{item.visibilityLabel}}</text>
            <text class="folder-count">{{item.photoCount}}</text>
          </button>
          <view wx:if="{{user.canManageFolders || item.canManageVisibility}}" class="folder-order-actions">
            <button class="folder-manage-button" data-slug="{{item.slug}}" bindtap="openFolderActions" aria-label="管理文件夹">···</button>
            <button wx:if="{{user.canManageFolders}}" data-index="{{index}}" data-direction="-1" bindtap="moveFolderOrder" disabled="{{index === 0 || reorderingFolders}}" aria-label="上移文件夹">↑</button>
            <button wx:if="{{user.canManageFolders}}" data-index="{{index}}" data-direction="1" bindtap="moveFolderOrder" disabled="{{index === folders.length - 1 || reorderingFolders}}" aria-label="下移文件夹">↓</button>
          </view>
        </view>
        <view wx:if="{{user.canDelete}}" class="folder-menu-row recycle-menu-row">
          <button class="folder-menu-main {{recycleMode ? 'active' : ''}}" bindtap="chooseRecycleBin">
            <text>回收站</text><text class="folder-count">{{recycleCount}}</text>
          </button>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="content-heading">
    <view>
      <text class="folder-title">{{selectedFolderName}}</text>
      <text class="photo-count">{{total}} 项影像</text>
    </view>
    <view wx:if="{{user.canUpload || user.canEdit || user.canDelete}}" class="heading-actions">
      <button wx:if="{{user.canEdit || user.canDelete}}" class="edit-button {{editMode ? 'active' : ''}}" bindtap="toggleEditMode" disabled="{{uploading || batchSaving || photos.length === 0}}">{{editMode ? '完成' : '编辑'}}</button>
      <button wx:if="{{user.canUpload && !editMode && !recycleMode}}" class="upload-button" bindtap="chooseMedia" disabled="{{uploading}}">＋ 上传</button>
    </view>
  </view>

  <view class="recycle-notice" wx:if="{{recycleMode}}">回收站中的影像保留 7 天，到期后自动永久删除。</view>

  <view class="skeleton-grid" wx:if="{{loading}}">
    <view class="skeleton-item" wx:for="{{skeletons}}" wx:key="*this">
      <view class="skeleton-image" />
      <view class="skeleton-line" />
      <view class="skeleton-line short" />
    </view>
  </view>
  <view class="error-state" wx:elif="{{error}}">
    <text>{{error}}</text>
    <button bindtap="retry">重新加载</button>
  </view>
  <view class="empty-state" wx:elif="{{photos.length === 0}}">
    <text class="empty-title">{{recycleMode ? '回收站是空的' : '这里还没有影像'}}</text>
    <text class="empty-copy">{{recycleMode ? '删除的影像会在这里保留 7 天。' : user.canUpload ? '点击上传，添加第一张照片或视频。' : '可上传用户添加后，这里就会出现新的影像。'}}</text>
  </view>
  <view class="media-grid" wx:else>
    <view class="media-item {{item.selected ? 'selected' : ''}}" wx:for="{{photos}}" wx:key="id" data-id="{{item.id}}" bindtap="openMedia">
      <view class="media-preview">
        <image wx:if="{{item.thumbnailUrl}}" src="{{item.thumbnailUrl}}" mode="aspectFill" lazy-load data-id="{{item.id}}" binderror="thumbnailError" />
        <view wx:else class="video-placeholder"><text>{{item.video ? '视频' : '影像'}}</text></view>
        <view wx:if="{{item.video}}" class="video-play-overlay">
          <view class="play-button"><view class="play-triangle" /></view>
        </view>
        <button wx:if="{{user.canEdit && !editMode}}" class="media-more" data-id="{{item.id}}" catchtap="openMediaActions" aria-label="重命名文件">···</button>
        <view wx:if="{{editMode}}" class="media-select {{item.selected ? 'checked' : ''}}">{{item.selected ? '✓' : ''}}</view>
      </view>
      <view class="media-copy">
        <text class="media-name">{{item.name}}</text>
        <text class="media-meta">{{item.dateLabel}} · {{item.sizeLabel}}</text>
        <text class="media-operator">{{item.operatorLabel}}{{item.operatorDateLabel ? ' · ' + item.operatorDateLabel : ''}}</text>
        <text wx:if="{{recycleMode && item.purgeDateLabel}}" class="purge-date">{{item.purgeDateLabel}} 后永久删除</text>
      </view>
    </view>
  </view>
  <view class="load-more" wx:if="{{loadingMore}}">正在加载更多</view>
  <view class="load-more" wx:elif="{{photos.length > 0 && !hasMore}}">已经看到全部影像</view>

  <view class="batch-toolbar" wx:if="{{editMode}}">
    <view class="batch-summary">
      <button bindtap="toggleAllLoaded">{{allLoadedSelected ? '取消全选' : photos.length > 100 ? '选择前100项' : '全选已加载'}}</button>
      <text>已选择 {{batchSelectedCount}} 项</text>
    </view>
    <view class="batch-actions" wx:if="{{recycleMode}}">
      <button class="batch-move" bindtap="restoreSelectedMedia" disabled="{{!batchSelectedCount || batchSaving}}" loading="{{batchSaving}}">恢复</button>
      <button class="batch-delete" bindtap="confirmPermanentDelete" disabled="{{!batchSelectedCount || batchSaving}}">永久删除</button>
    </view>
    <view class="batch-actions" wx:else>
      <button wx:if="{{user.canEdit}}" class="batch-move" bindtap="openBatchMove" disabled="{{!batchSelectedCount || batchSaving}}">移动到</button>
      <button wx:if="{{user.canDelete}}" class="batch-delete" bindtap="confirmBatchDelete" disabled="{{!batchSelectedCount || batchSaving}}">移入回收站</button>
    </view>
  </view>

  <view class="selection-backdrop" wx:if="{{renameOpen}}" bindtap="closeRename">
    <view class="selection-dialog" catchtap="noop">
      <text class="dialog-eyebrow">{{renameKind === 'folder' ? '重命名文件夹' : '重命名文件'}}</text>
      <text class="dialog-title">{{renameTarget.name}}</text>
      <input
        class="folder-name-input"
        value="{{renameValue}}"
        bindinput="updateRenameValue"
        bindconfirm="saveRename"
        confirm-type="done"
        focus="{{renameOpen}}"
        maxlength="{{renameMaxLength}}"
      />
      <view class="dialog-actions">
        <button class="cancel-button" bindtap="closeRename" disabled="{{renaming}}">取消</button>
        <button class="dialog-primary-button" bindtap="saveRename" disabled="{{renaming || !renameValue}}" loading="{{renaming}}">保存</button>
      </view>
    </view>
  </view>

  <view class="selection-backdrop" wx:if="{{folderVisibilityOpen}}" bindtap="closeFolderVisibility">
    <view class="selection-dialog" catchtap="noop">
      <text class="dialog-eyebrow">修改可见范围</text>
      <text class="dialog-title">{{managedFolder.name}}</text>
      <text class="dialog-copy">没有权限的人不会在目录、全部影像或搜索结果中看到这个文件夹。</text>
      <view class="visibility-options">
        <button class="visibility-option {{folderVisibility === 'all' ? 'active' : ''}}" data-type="all" bindtap="setFolderVisibility"><text>所有人可见</text><text>任何注册用户</text></button>
        <button class="visibility-option {{folderVisibility === 'admins' ? 'active' : ''}}" data-type="admins" bindtap="setFolderVisibility"><text>管理者可见</text><text>仅文件夹管理者</text></button>
        <button class="visibility-option {{folderVisibility === 'specific' ? 'active' : ''}}" data-type="specific" bindtap="setFolderVisibility"><text>某些人可见</text><text>仅勾选用户</text></button>
      </view>
      <checkbox-group wx:if="{{folderVisibility === 'specific'}}" class="visibility-users" bindchange="updateFolderVisibleUsers">
        <label wx:for="{{visibilityUsers}}" wx:for-item="visibilityUser" wx:key="id">
          <checkbox value="{{visibilityUser.id}}" checked="{{visibilityUser.folderSelected}}" disabled="{{visibilityUser.id === managedFolder.creatorUserId}}" />
          <view><text>{{visibilityUser.displayName}}</text><text>{{visibilityUser.accountLabel}}</text></view>
          <text>{{visibilityUser.permissionLabel}}</text>
        </label>
      </checkbox-group>
      <view class="dialog-actions">
        <button class="cancel-button" bindtap="closeFolderVisibility" disabled="{{folderVisibilitySaving}}">取消</button>
        <button class="dialog-primary-button" bindtap="saveFolderVisibility" disabled="{{folderVisibilitySaving || (folderVisibility === 'specific' && !folderVisibleUserIds.length)}}" loading="{{folderVisibilitySaving}}">保存</button>
      </view>
    </view>
  </view>

  <view class="selection-backdrop" wx:if="{{createFolderOpen}}" bindtap="closeCreateFolder">
    <view class="selection-dialog" catchtap="noop">
      <text class="dialog-eyebrow">新建文件夹</text>
      <text class="dialog-title">整理新的回忆</text>
      <text class="dialog-copy">创建后会直接进入这个文件夹，可以继续上传照片或视频。</text>
      <input
        class="folder-name-input"
        value="{{newFolderName}}"
        bindinput="updateNewFolderName"
        bindconfirm="createFolder"
        confirm-type="done"
        focus="{{createFolderOpen}}"
        maxlength="80"
        placeholder="例如：2026 青岛旅行"
      />
      <view class="visibility-options">
        <button class="visibility-option {{newFolderVisibility === 'all' ? 'active' : ''}}" data-type="all" bindtap="setNewFolderVisibility"><text>所有人可见</text><text>任何注册用户</text></button>
        <button class="visibility-option {{newFolderVisibility === 'admins' ? 'active' : ''}}" data-type="admins" bindtap="setNewFolderVisibility"><text>管理者可见</text><text>仅文件夹管理者</text></button>
        <button class="visibility-option {{newFolderVisibility === 'specific' ? 'active' : ''}}" data-type="specific" bindtap="setNewFolderVisibility"><text>某些人可见</text><text>仅勾选用户</text></button>
      </view>
      <checkbox-group wx:if="{{newFolderVisibility === 'specific'}}" class="visibility-users" bindchange="updateNewVisibleUsers">
        <label wx:for="{{visibilityUsers}}" wx:for-item="visibilityUser" wx:key="id">
          <checkbox value="{{visibilityUser.id}}" checked="{{visibilityUser.newSelected}}" disabled="{{visibilityUser.id === user.id}}" />
          <view><text>{{visibilityUser.displayName}}</text><text>{{visibilityUser.accountLabel}}</text></view>
          <text>{{visibilityUser.permissionLabel}}</text>
        </label>
      </checkbox-group>
      <view class="dialog-actions">
        <button class="cancel-button" bindtap="closeCreateFolder" disabled="{{creatingFolder}}">取消</button>
        <button class="dialog-primary-button" bindtap="createFolder" disabled="{{creatingFolder || !newFolderName || (newFolderVisibility === 'specific' && !newFolderVisibleUserIds.length)}}" loading="{{creatingFolder}}">创建</button>
      </view>
    </view>
  </view>

  <view class="selection-backdrop" wx:if="{{userManagementOpen}}" bindtap="closeUserManagement">
    <view class="selection-dialog people-dialog" catchtap="noop">
      <text class="dialog-eyebrow">训练营成员</text>
      <text class="dialog-title">称号管理</text>
      <text class="dialog-copy">你可以授予或修改成员称号，但看不到成员权限设置。</text>
      <view class="people-loading" wx:if="{{managedUsersLoading}}">正在读取人员信息</view>
      <scroll-view wx:else class="people-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="people-row" wx:for="{{managedUsers}}" wx:key="id">
          <view class="people-heading">
            <view><text class="people-name">{{item.displayName}}</text><text class="people-account">{{item.accountLabel}}</text></view>
            <text class="people-title-badge">仅称号</text>
          </view>
          <view class="people-title-edit">
            <input value="{{item.title}}" data-id="{{item.id}}" bindinput="updateManagedTitle" maxlength="20" placeholder="设置称号" />
            <button data-id="{{item.id}}" bindtap="saveManagedTitle" loading="{{userSavingId === item.id}}">保存</button>
          </view>
        </view>
        <view class="people-empty" wx:if="{{!managedUsers.length}}">还没有人员记录</view>
      </scroll-view>
      <view class="dialog-actions">
        <button class="dialog-primary-button people-close" bindtap="closeUserManagement" disabled="{{userSavingId !== ''}}">完成</button>
      </view>
    </view>
  </view>

  <view class="selection-backdrop" wx:if="{{selectionOpen}}">
    <view class="selection-dialog" catchtap="noop">
      <text class="dialog-eyebrow">批量上传</text>
      <text class="dialog-title">已选择 {{selectedCount}} / 50 项</text>
      <text class="dialog-copy">{{selectedImageCount}} 张照片 · {{selectedVideoCount}} 个视频。每轮最多添加 9 项，可以连续添加多轮。</text>
      <view class="selection-actions">
        <button
          class="selection-more"
          bindtap="addMoreMedia"
          loading="{{selectingMedia}}"
          disabled="{{selectingMedia || selectedCount >= 50}}"
        >继续添加</button>
        <button
          class="selection-upload"
          bindtap="uploadSelectedMedia"
          disabled="{{selectingMedia || !selectedCount}}"
        >上传 {{selectedCount}} 项</button>
      </view>
      <button class="selection-cancel" bindtap="cancelMediaSelection" disabled="{{selectingMedia}}">取消本次选择</button>
    </view>
  </view>

  <view class="selection-backdrop" wx:if="{{batchMoveOpen}}" bindtap="closeBatchMove">
    <view class="selection-dialog" catchtap="noop">
      <text class="dialog-eyebrow">批量移动</text>
      <text class="dialog-title">移动 {{batchSelectedCount}} 项影像</text>
      <text class="dialog-copy">选择目标文件夹，原名称和影像信息会保留。</text>
      <picker mode="selector" range="{{moveFolderNames}}" value="{{moveFolderIndex}}" bindchange="updateMoveFolder">
        <view class="folder-picker">{{moveFolderNames[moveFolderIndex] || '请选择目标文件夹'}}</view>
      </picker>
      <view class="dialog-actions">
        <button class="cancel-button" bindtap="closeBatchMove" disabled="{{batchSaving}}">取消</button>
        <button class="dialog-primary-button" bindtap="moveSelectedMedia" disabled="{{batchSaving}}" loading="{{batchSaving}}">确认移动</button>
      </view>
    </view>
  </view>

  <view class="upload-status" wx:if="{{uploading}}">
    <view class="upload-status-copy">
      <text>{{uploadLabel}}</text>
      <text>{{uploadProgress}}%</text>
    </view>
    <view class="upload-track"><view class="upload-value" style="width: {{uploadProgress}}%" /></view>
  </view>
</view>
