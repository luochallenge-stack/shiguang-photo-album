.library-page { min-height: 100vh; padding-bottom: 48rpx; }
.library-page.editing { padding-bottom: 240rpx; }
.member-bar { display: flex; align-items: center; justify-content: space-between; gap: 22rpx; padding: 28rpx 28rpx 24rpx; color: #ffffff; background: #21483f; }
.identity { min-width: 0; display: flex; align-items: center; gap: 14rpx; }
.menu-button { width: 56rpx; height: 56rpx; flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 7rpx; margin: 0; padding: 0; border: 1rpx solid rgba(255,255,255,.25); border-radius: 8rpx; background: transparent; }
.menu-line { width: 26rpx; height: 3rpx; border-radius: 2rpx; background: #ffffff; }
.logo { width: 72rpx; height: 72rpx; flex: 0 0 auto; border-radius: 12rpx; }
.identity-copy { min-width: 0; }
.album-name, .member-name, .folder-title, .photo-count, .media-name, .media-meta, .empty-title, .empty-copy, .dialog-eyebrow, .dialog-title, .dialog-copy { display: block; }
.album-name { overflow: hidden; font-size: 28rpx; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.member-name { margin-top: 8rpx; color: rgba(255,255,255,.62); font-size: 21rpx; }
.logout-button { width: 92rpx; height: 56rpx; flex: 0 0 auto; margin: 0; padding: 0; border: 1rpx solid rgba(255,255,255,.28); border-radius: 10rpx; color: #ffffff; background: transparent; font-size: 22rpx; line-height: 56rpx; }
.folder-menu-backdrop { position: fixed; z-index: 30; top: 0; right: 0; bottom: 0; left: 0; background: rgba(13,25,21,.52); }
.folder-menu-panel { width: 84vw; max-width: 640rpx; height: 100%; display: flex; flex-direction: column; padding: 32rpx 24rpx calc(24rpx + env(safe-area-inset-bottom)); background: #ffffff; box-shadow: 18rpx 0 42rpx rgba(12,31,25,.24); box-sizing: border-box; }
.folder-menu-header { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; padding: 8rpx 4rpx 24rpx; border-bottom: 1rpx solid #e1e7e4; }
.folder-menu-eyebrow, .folder-menu-title { display: block; }
.folder-menu-eyebrow { color: #8a9692; font-size: 19rpx; }
.folder-menu-title { margin-top: 5rpx; color: #243a34; font-size: 34rpx; font-weight: 700; }
.folder-menu-close { width: 56rpx; height: 56rpx; margin: 0; padding: 0; border-radius: 8rpx; color: #53625d; background: #edf1ef; font-size: 34rpx; line-height: 54rpx; }
.create-folder-menu-button { width: 100%; height: 72rpx; flex: 0 0 auto; margin: 22rpx 0 14rpx; border-radius: 8rpx; color: #ffffff; background: #b85246; font-size: 24rpx; font-weight: 700; line-height: 72rpx; }
.create-folder-menu-button[disabled] { color: rgba(255,255,255,.72); background: #b88b85; }
.folder-menu-list { height: 0; min-height: 0; flex: 1; }
.folder-menu-row { display: flex; align-items: center; gap: 10rpx; border-bottom: 1rpx solid #edf1ef; }
.folder-menu-main { min-width: 0; height: 76rpx; flex: 1; display: flex; align-items: center; gap: 10rpx; margin: 0; padding: 0 14rpx; border-radius: 0; color: #53625d; background: transparent; font-size: 23rpx; line-height: 76rpx; text-align: left; }
.folder-menu-main.active { color: #21483f; background: #e4efeb; font-weight: 700; }
.folder-menu-name { min-width: 0; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.folder-count { margin-left: auto; color: #8a9692; font-size: 19rpx; }
.folder-order-actions { flex: 0 0 auto; display: flex; gap: 6rpx; }
.folder-order-actions button { width: 48rpx; height: 48rpx; margin: 0; padding: 0; border: 1rpx solid #d7dfdc; border-radius: 8rpx; color: #36594f; background: #f4f7f6; font-size: 25rpx; line-height: 46rpx; }
.folder-order-actions button[disabled] { color: #b3bcb9; background: #f0f2f1; }
.folder-order-actions .folder-manage-button { color: #ffffff; border-color: #21483f; background: #21483f; font-size: 22rpx; letter-spacing: 0; }
.recycle-menu-row { margin-top: 16rpx; border-top: 1rpx solid #dfe5e2; }
.visibility-mark { flex: 0 0 auto; padding: 2rpx 7rpx; border-radius: 5rpx; color: #4e625c; background: #e9eeec; font-size: 16rpx; line-height: 28rpx; }
.visibility-mark.admins { color: #775c19; background: #fff0b8; }
.visibility-mark.specific { color: #7b4740; background: #f7dfdb; }
.content-heading { display: flex; align-items: flex-end; justify-content: space-between; padding: 32rpx 28rpx 20rpx; }
.folder-title { font-size: 34rpx; font-weight: 700; }
.photo-count { margin-top: 8rpx; color: #7b8783; font-size: 21rpx; }
.upload-button { width: 126rpx; height: 64rpx; flex: 0 0 auto; margin: 0; padding: 0; border-radius: 8rpx; color: #ffffff; background: #b85246; font-size: 23rpx; font-weight: 700; line-height: 64rpx; }
.upload-button[disabled] { color: rgba(255,255,255,.75); background: #b88b85; }
.heading-actions { display: flex; align-items: center; gap: 12rpx; }
.edit-button { width: 106rpx; height: 64rpx; margin: 0; padding: 0; border: 1rpx solid #cad5d1; border-radius: 8rpx; color: #42544e; background: #ffffff; font-size: 23rpx; line-height: 62rpx; }
.edit-button.active { border-color: #9dbdb3; color: #21483f; background: #e4efeb; }
.edit-button[disabled] { color: #a0aaa6; background: #edf0ef; }
.recycle-notice { margin: 0 28rpx 22rpx; padding: 18rpx 20rpx; border: 1rpx solid #d8dfdc; border-radius: 8rpx; color: #5e6b67; background: #f3f6f5; font-size: 21rpx; line-height: 1.5; }
.skeleton-grid { display: flex; flex-wrap: wrap; gap: 18rpx; padding: 0 28rpx; }
.skeleton-item { width: calc((100% - 18rpx) / 2); overflow: hidden; border: 1rpx solid #e0e6e3; border-radius: 12rpx; background: #ffffff; box-sizing: border-box; }
.skeleton-image { height: 328rpx; background: #e4e9e7; }
.skeleton-line { width: 72%; height: 20rpx; margin: 20rpx 18rpx 0; border-radius: 4rpx; background: #e8ecea; }
.skeleton-line.short { width: 44%; margin-top: 12rpx; margin-bottom: 20rpx; }
.media-grid { display: flex; flex-wrap: wrap; gap: 18rpx; padding: 0 28rpx; }
.media-item { width: calc((100% - 18rpx) / 2); min-width: 0; overflow: hidden; border: 1rpx solid #dfe5e2; border-radius: 12rpx; background: #ffffff; box-sizing: border-box; }
.media-item.selected { border-color: #21483f; box-shadow: 0 0 0 3rpx rgba(33,72,63,.15); }
.media-preview { position: relative; width: 100%; height: 328rpx; overflow: hidden; background: #e9eeec; }
.media-preview image { width: 100%; height: 100%; display: block; }
.video-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #5d6d67; background: #dfe9e6; font-size: 21rpx; }
.video-play-overlay { position: absolute; z-index: 1; top: 0; right: 0; bottom: 0; left: 0; display: flex; align-items: center; justify-content: center; background: rgba(9,18,15,.12); }
.play-button { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; color: #ffffff; background: #21483f; }
.play-triangle { width: 0; height: 0; margin-left: 6rpx; border-top: 12rpx solid transparent; border-bottom: 12rpx solid transparent; border-left: 18rpx solid #ffffff; }
.media-copy { padding: 18rpx; }
.media-name { overflow: hidden; font-size: 24rpx; font-weight: 600; text-overflow: ellipsis; white-space: nowrap; }
.media-meta { margin-top: 9rpx; overflow: hidden; color: #83908c; font-size: 19rpx; text-overflow: ellipsis; white-space: nowrap; }
.media-operator, .purge-date { display: block; margin-top: 8rpx; overflow: hidden; font-size: 18rpx; text-overflow: ellipsis; white-space: nowrap; }
.media-operator { color: #38695d; }
.purge-date { color: #b85246; }
.media-select { position: absolute; z-index: 2; top: 16rpx; right: 16rpx; width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid #ffffff; border-radius: 50%; color: #ffffff; background: rgba(17,23,21,.52); box-shadow: 0 4rpx 14rpx rgba(0,0,0,.2); box-sizing: border-box; font-size: 28rpx; font-weight: 700; }
.media-select.checked { border-color: #21483f; background: #21483f; }
.media-more { position: absolute; z-index: 3; top: 14rpx; right: 14rpx; width: 54rpx; height: 48rpx; margin: 0; padding: 0; border: 1rpx solid rgba(255,255,255,.5); border-radius: 8rpx; color: #ffffff; background: rgba(20,35,30,.72); font-size: 24rpx; line-height: 45rpx; letter-spacing: 0; }
.load-more { padding: 30rpx 28rpx 8rpx; color: #8a9692; font-size: 21rpx; text-align: center; }
.batch-toolbar { position: fixed; z-index: 16; right: 0; bottom: 0; left: 0; padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid #d9e0dd; background: #ffffff; box-shadow: 0 -10rpx 28rpx rgba(18,45,38,.12); }
.batch-summary, .batch-actions { display: flex; align-items: center; justify-content: space-between; gap: 14rpx; }
.batch-summary { margin-bottom: 14rpx; color: #66736f; font-size: 21rpx; }
.batch-summary button { width: auto; height: 48rpx; margin: 0; padding: 0 14rpx; color: #21483f; background: #e4efeb; font-size: 20rpx; line-height: 48rpx; }
.batch-actions button { width: 50%; height: 70rpx; margin: 0; border-radius: 8rpx; font-size: 23rpx; font-weight: 700; line-height: 70rpx; }
.batch-move { color: #21483f; background: #e4efeb; }
.batch-delete { color: #ffffff; background: #b85246; }
.batch-actions button[disabled] { color: #9ca6a2; background: #e8ecea; }
.loading, .empty-state, .error-state { min-height: 460rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40rpx; color: #7a8883; font-size: 24rpx; text-align: center; }
.empty-title { color: #31413c; font-size: 29rpx; font-weight: 700; }
.empty-copy { margin-top: 14rpx; line-height: 1.6; }
.error-state button { height: 66rpx; margin-top: 24rpx; padding: 0 28rpx; border-radius: 8rpx; color: #ffffff; background: #21483f; font-size: 22rpx; line-height: 66rpx; }
.dialog-eyebrow { color: #b85246; font-size: 21rpx; font-weight: 700; }
.dialog-title { margin-top: 12rpx; font-size: 35rpx; font-weight: 700; }
.dialog-copy { margin-top: 12rpx; color: #74827e; font-size: 23rpx; line-height: 1.55; }
.folder-name-input { height: 82rpx; margin-top: 28rpx; padding: 0 22rpx; border: 1rpx solid #cbd6d2; border-radius: 10rpx; font-size: 28rpx; }
.dialog-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.dialog-actions button { height: 78rpx; margin: 0; border-radius: 10rpx; font-size: 24rpx; font-weight: 700; line-height: 78rpx; }
.cancel-button { width: 38%; color: #53625d; background: #edf1ef; }
.dialog-primary-button { width: 62%; color: #ffffff; background: #21483f; }
.dialog-primary-button[disabled] { color: rgba(255,255,255,.7); background: #6f8982; }
.selection-backdrop { position: fixed; z-index: 22; top: 0; right: 0; bottom: 0; left: 0; display: flex; align-items: flex-end; background: rgba(13,25,21,.52); }
.selection-dialog { width: 100%; max-height: 92vh; overflow-y: auto; padding: 38rpx 36rpx calc(30rpx + env(safe-area-inset-bottom)); border-radius: 18rpx 18rpx 0 0; background: #ffffff; box-sizing: border-box; }
.visibility-options { display: flex; gap: 10rpx; margin-top: 26rpx; }
.visibility-option { width: calc((100% - 20rpx) / 3); min-width: 0; height: 104rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; margin: 0; padding: 0 6rpx; border: 1rpx solid #d6dfdc; border-radius: 8rpx; color: #53625d; background: #f7f9f8; line-height: 1.2; }
.visibility-option text:first-child { font-size: 22rpx; font-weight: 700; }
.visibility-option text:last-child { color: #82908b; font-size: 17rpx; }
.visibility-option.active { border-color: #21483f; color: #21483f; background: #e4efeb; }
.visibility-users { display: block; max-height: 360rpx; overflow-y: auto; margin-top: 18rpx; border: 1rpx solid #dbe2df; border-radius: 8rpx; }
.visibility-users label { min-height: 78rpx; display: grid; grid-template-columns: 42rpx minmax(0, 1fr) auto; align-items: center; gap: 12rpx; padding: 8rpx 16rpx; border-bottom: 1rpx solid #edf1ef; box-sizing: border-box; }
.visibility-users label:last-child { border-bottom: 0; }
.visibility-users checkbox { transform: scale(.8); transform-origin: left center; }
.visibility-users label view { min-width: 0; }
.visibility-users label view text { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.visibility-users label view text:first-child { color: #31413c; font-size: 22rpx; font-weight: 600; }
.visibility-users label view text:last-child { margin-top: 4rpx; color: #899590; font-size: 18rpx; }
.visibility-users label > text { color: #6f7c78; font-size: 18rpx; }
.selection-actions { display: flex; gap: 16rpx; margin-top: 28rpx; }
.selection-actions button { width: 50%; height: 78rpx; margin: 0; border-radius: 10rpx; font-size: 24rpx; font-weight: 700; line-height: 78rpx; }
.selection-more { color: #21483f; background: #e4ece9; }
.selection-upload { color: #ffffff; background: #b85246; }
.selection-actions button[disabled] { color: #9ba6a2; background: #e7ebe9; }
.selection-cancel { width: 100%; height: 66rpx; margin: 16rpx 0 0; color: #73807c; background: transparent; font-size: 22rpx; line-height: 66rpx; }
.folder-picker { height: 82rpx; margin-top: 26rpx; padding: 0 22rpx; overflow: hidden; border: 1rpx solid #cbd6d2; border-radius: 10rpx; color: #31413c; background: #ffffff; font-size: 26rpx; line-height: 82rpx; text-overflow: ellipsis; white-space: nowrap; }
.upload-status { position: fixed; z-index: 18; right: 24rpx; bottom: calc(24rpx + env(safe-area-inset-bottom)); left: 24rpx; padding: 22rpx 24rpx; border-radius: 10rpx; color: #ffffff; background: #21483f; box-shadow: 0 12rpx 36rpx rgba(18,45,38,.22); }
.upload-status-copy { display: flex; align-items: center; justify-content: space-between; font-size: 22rpx; }
.upload-track { height: 8rpx; margin-top: 16rpx; overflow: hidden; border-radius: 4rpx; background: rgba(255,255,255,.2); }
.upload-value { height: 100%; border-radius: 4rpx; background: #ffd25f; transition: width .18s ease; }
