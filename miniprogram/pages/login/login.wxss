.login-page { min-height: 100vh; background: #ffffff; }
.brand-area { padding: calc(36rpx + env(safe-area-inset-top)) 48rpx 48rpx; color: #ffffff; background: #21483f; }
.brand-logo { width: 92rpx; height: 92rpx; display: block; border-radius: 14rpx; }
.brand-title, .brand-copy, .security-copy, .auth-title, .auth-copy, .eyebrow { display: block; }
.brand-title { margin-top: 36rpx; font-size: 48rpx; font-weight: 700; line-height: 1.24; }
.brand-copy { margin-top: 18rpx; color: rgba(255,255,255,.72); font-size: 26rpx; line-height: 1.7; }
.brand-rule { height: 1rpx; margin-top: 38rpx; background: rgba(255,255,255,.18); }
.security-copy { margin-top: 24rpx; color: rgba(255,255,255,.68); font-size: 23rpx; line-height: 1.55; }
.auth-area { padding: 46rpx 48rpx 64rpx; }
.eyebrow { color: #b85246; font-size: 21rpx; font-weight: 700; }
.auth-title { margin-top: 14rpx; font-size: 43rpx; font-weight: 700; }
.auth-copy { margin-top: 14rpx; color: #71807b; font-size: 24rpx; line-height: 1.55; }
.mode-switch { display: flex; gap: 6rpx; margin-top: 32rpx; padding: 6rpx; border: 1rpx solid #dce3e0; border-radius: 12rpx; }
.mode-button { width: 50%; height: 72rpx; display: flex; align-items: center; justify-content: center; margin: 0; padding: 0; border-radius: 8rpx; color: #66736f; background: transparent; font-size: 24rpx; font-weight: 700; line-height: 72rpx; }
.mode-button.active { color: #21483f; background: #dceee9; }
.field { margin-top: 24rpx; }
.field text { display: block; margin-bottom: 12rpx; color: #45534f; font-size: 22rpx; font-weight: 600; }
.field input { height: 82rpx; padding: 0 22rpx; border: 1rpx solid #ccd6d2; border-radius: 10rpx; background: #ffffff; font-size: 27rpx; }
.error { margin-top: 22rpx; padding: 18rpx 20rpx; border: 1rpx solid #e8beb9; border-radius: 10rpx; color: #a93e32; background: #fff1ef; font-size: 23rpx; }
.submit-button { height: 84rpx; display: flex; align-items: center; justify-content: center; margin-top: 30rpx; border-radius: 10rpx; color: #ffffff; background: #21483f; font-size: 25rpx; font-weight: 700; line-height: 84rpx; }
.submit-button[disabled] { color: rgba(255,255,255,.7); background: #55746d; }
